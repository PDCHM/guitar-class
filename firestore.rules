// ⚠ TEMPORARY DEBUG RULES — WIDE OPEN ⚠
//
// These rules allow ANY caller (authenticated or not) to read and write ANY
// document in the database. They exist temporarily to diagnose a write that
// was failing silently — specifically, songs/{id}.visibleTo updates from the
// admin form when admin isn't Firebase-authenticated.
//
// Revert to least-privilege rules before exposing this Firebase project to
// untrusted traffic. The Firebase API key and project id are visible in the
// public HTML, so any visitor can call Firestore directly under these rules.
//
// To deploy this file:
//   firebase deploy --only firestore:rules
//
// To restore safer behaviour, ask Claude to regenerate the rules with the
// least-privilege template that lived in this file before.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /songs/{songId} {
      allow read: if true;
      allow write: if true;
    }
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
